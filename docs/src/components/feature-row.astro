---
const props = Astro.props;
const { title, description, tint = '#f5f5f5' } = props;
---

<div class="rounded-xl p-4 transition-shadow hover:shadow-[0_2px_8px_rgba(0,0,0,0.06)]" style={`background: ${tint}`}>
  <div class="size-9 rounded-lg bg-white flex items-center justify-center mb-3 shadow-[0_1px_2px_rgba(0,0,0,0.05)]">
    <slot />
  </div>
  <strong class="text-[13.5px] font-semibold text-text block">{title}</strong>
  <p class="text-[13px] text-text-tertiary mt-1 leading-[1.45]">{description}</p>
</div>
